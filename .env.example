# Port du serveur (défaut: 3000)
PORT=3000

# MongoDB — Option 1 : URI complète (recommandé pour Atlas / Render)
# Mettre le nom de la base APRÈS le host : ...mongodb.net/ma3ak?...
# Local :
# MONGODB_URI=mongodb://localhost:27017/ma3ak
# Atlas (exemple — remplacer USER et PASSWORD, encoder les caractères spéciaux dans PASSWORD) :
# MONGODB_URI=mongodb+srv://USER:PASSWORD@m3ak-cluster.odf3ppp.mongodb.net/ma3ak?retryWrites=true&w=majority

# MongoDB Atlas — Option 2 : variables séparées (évite une URI longue)
# Créer un cluster sur https://cloud.mongodb.com, puis récupérer :
# - DB_CLUSTER = host du cluster (ex. cluster0.xxxxx.mongodb.net)
# - DB_USERNAME = utilisateur base de données
# - DB_PASSWORD = mot de passe (éviter les caractères spéciaux non encodés)
# - DB_NAME = nom de la base (défaut: ma3ak)
# DB_USERNAME=
# DB_PASSWORD=
# DB_CLUSTER=cluster0.xxxxx.mongodb.net
# DB_NAME=ma3ak
#
# Déploiement (Render, Railway, etc.) : dans Atlas → Network Access, ajouter une entrée
# autorisant les IP du cloud (souvent 0.0.0.0/0 pour les hébergeurs sans IP fixe).
# Puis définir la même MONGODB_URI (ou DB_*) dans les variables d'environnement du service.

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise
JWT_EXPIRES_IN=7d

# CORS (optionnel, séparé par des virgules)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Google OAuth2 (pour login Google)
GOOGLE_CLIENT_ID=votre_google_client_id

# OpenStreetMap / Map (optionnel — valeurs par défaut si non défini)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
# Overpass API (POI / lieux dans une zone) — instance publique par défaut
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# API Flask Transport adapté (matching intelligent, ETA) — optionnel
# Si défini, NestJS appellera cette URL pour /api/match et /api/eta
FLASK_TRANSPORT_URL=http://localhost:5001

# Transport — rayon matching (km), tarification TND (base + km + minute)
# TRANSPORT_MATCHING_RADIUS_KM=15
# TRANSPORT_FARE_BASE_TND=2.5
# TRANSPORT_FARE_PER_KM_TND=0.8
# TRANSPORT_FARE_PER_MINUTE_TND=0.15

# Notifications push (optionnel — sans clé, seules les notifs en base sont créées)
# FCM_SERVER_KEY=

# Ollama — IA locale (optionnel ; si absent, considéré activé avec repli heuristique si injoignable)
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava
# OLLAMA_TIMEOUT_MS=120000
